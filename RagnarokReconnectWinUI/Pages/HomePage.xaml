<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="RagnarokReconnectWinUI.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:RagnarokReconnectWinUI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Monitoring" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Start Monitoring" Click="StartMonitoring_Click" />
            <Button Content="Stop Monitoring" Click="StopMonitoring_Click" />
            <Button Content="Run One Poll" Click="PollNow_Click" />
            <TextBlock
                x:Name="StatusText"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <TextBlock
            Grid.Row="2"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="Live process health and alert/relogin toggles for each detected character." />

        <ListView Grid.Row="3" ItemsSource="{x:Bind ProcessStates, Mode=OneWay}">
            <ListView.Header>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="PID" />
                    <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Process" />
                    <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Character" />
                    <TextBlock Grid.Column="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Username" />
                    <TextBlock Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Status" />
                    <TextBlock Grid.Column="5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Remote Ports" />
                    <TextBlock Grid.Column="6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Cause" />
                    <TextBlock Grid.Column="7" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Alert" />
                    <TextBlock Grid.Column="8" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Relogin" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4,0,4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ProcessId}" />
                        <TextBlock Grid.Column="1" Text="{Binding ProcessName}" />
                        <TextBlock Grid.Column="2" Text="{Binding CharacterName}" />
                        <TextBlock Grid.Column="3" Text="{Binding Username}" />
                        <TextBlock Grid.Column="4" Text="{Binding State}" />
                        <TextBlock Grid.Column="5" Text="{Binding RemotePorts}" />
                        <TextBlock Grid.Column="6" Text="{Binding RootCause}" />
                        <CheckBox Grid.Column="7" IsChecked="{Binding AlertEnabled, Mode=TwoWay}" Checked="ToggleChanged" Unchecked="ToggleChanged" />
                        <CheckBox Grid.Column="8" IsChecked="{Binding ReloginEnabled, Mode=TwoWay}" Checked="ToggleChanged" Unchecked="ToggleChanged" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="4" Style="{StaticResource SubtitleTextBlockStyle}" Text="Recent Alerts" />

        <ListView Grid.Row="5" ItemsSource="{x:Bind Incidents, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4,0,4" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{Binding CharacterName}" />
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding Timestamp}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding State}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding RootCause}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Evidence}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
