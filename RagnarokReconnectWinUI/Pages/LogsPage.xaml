<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="RagnarokReconnectWinUI.Pages.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Logs" />
            <Button Grid.Column="1" Content="Refresh Dump" Click="RefreshDump_Click" />
        </Grid>

        <ListView Grid.Row="1" ItemsSource="{x:Bind Incidents, Mode=OneWay}">
            <ListView.Header>
                <TextBlock
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Recent Incidents" />
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4,0,4" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{Binding CharacterName}" />
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding Timestamp}" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding State}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding RootCause}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding DeliveredToDiscord}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Evidence}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Diagnostic Dump (Ctrl+A / Ctrl+C)" />
            <Button Grid.Column="1" Content="Copy Dump" Click="CopyDump_Click" />
        </Grid>

        <TextBox
            x:Name="DiagnosticDumpTextBox"
            Grid.Row="3"
            AcceptsReturn="True"
            IsReadOnly="True"
            TextWrapping="NoWrap" />
    </Grid>
</Page>
