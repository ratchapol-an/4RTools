<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="RagnarokReconnectWinUI.Pages.NotificationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Notification Settings" />
        <TextBlock
            Grid.Row="1"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="Map usernames to Discord User IDs and validate delivery with Test Send." />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <ComboBox
                x:Name="UsernameDropdown"
                Width="360"
                Header="Username"
                ItemsSource="{x:Bind AvailableUsers, Mode=OneWay}"
                SelectionChanged="UsernameDropdown_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox x:Name="DiscordUserIdInput" Width="280" Header="Discord User ID (numeric)" />
            <Button VerticalAlignment="Bottom" Content="Add / Update" Click="SaveUser_Click" />
            <Button VerticalAlignment="Bottom" Content="Save All" Click="SaveAll_Click" />
        </StackPanel>

        <StackPanel Grid.Row="3" Spacing="8">
            <TextBlock
                x:Name="StatusText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Use Test Send to verify each Discord User ID." />
            <ListView ItemsSource="{x:Bind Users, Mode=OneWay}">
            <ListView.Header>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Username" />
                    <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Discord User ID" />
                    <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Edit" />
                    <TextBlock Grid.Column="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Test" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4,0,4" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{Binding DisplayVisibility}">
                                <TextBlock Width="180" Style="{StaticResource BodyStrongTextBlockStyle}" Text="{Binding Username}" />
                                <TextBlock Width="280" Text="{Binding DiscordUserIdDisplay}" />
                                <Button Width="100" Content="Edit" Click="EditUser_Click" />
                                <Button Width="100" Content="Test Send" Click="TestSend_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{Binding EditVisibility}">
                                <TextBlock Width="180" Style="{StaticResource BodyStrongTextBlockStyle}" Text="{Binding Username}" />
                                <TextBox Width="280" Text="{Binding EditDiscordUserId, Mode=TwoWay}" />
                                <Button Width="100" Content="Save" Click="SaveUserRow_Click" />
                                <Button Width="100" Content="Discard" Click="DiscardUserRow_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
